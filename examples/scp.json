{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowEverythingByDefault",
      "Effect": "Allow",
      "Action": "*",
      "Resource": "*"
    },
    {
      "Sid": "OrgWideProdDataLockdown",
      "Effect": "Deny",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::prod-data/*"
    }
  ]
}
