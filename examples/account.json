{
  "principals": [
    {
      "arn": "arn:aws:iam::111122223333:role/data-team",
      "policies": [
        {
          "name": "data-team-access",
          "document": {
            "Version": "2012-10-17",
            "Statement": [
              {
                "Effect": "Allow",
                "Action": ["s3:GetObject", "s3:ListBucket"],
                "Resource": [
                  "arn:aws:s3:::prod-data",
                  "arn:aws:s3:::prod-data/*"
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "arn": "arn:aws:iam::111122223333:role/ci-runner",
      "policies": [
        {
          "name": "ci-broad-read",
          "document": {
            "Version": "2012-10-17",
            "Statement": [
              {
                "Effect": "Allow",
                "Action": "s3:Get*",
                "Resource": "arn:aws:s3:::*"
              },
              {
                "Effect": "Deny",
                "Action": "s3:*",
                "Resource": "arn:aws:s3:::audit-logs/*"
              }
            ]
          }
        }
      ]
    },
    {
      "arn": "arn:aws:iam::111122223333:user/intern",
      "policies": [
        {
          "name": "intern-sandbox",
          "document": {
            "Version": "2012-10-17",
            "Statement": [
              {
                "Effect": "Allow",
                "Action": "s3:*",
                "Resource": "arn:aws:s3:::sandbox-*"
              }
            ]
          }
        }
      ]
    }
  ]
}
